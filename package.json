{
  "name": "demoshop-mobile-automation",
  "version": "1.0.0",
  "description": "Mobile test automation framework for DemoShop React Native app",
  "scripts": {
    "test": "wdio run config/wdio.conf.ts",
    "test:loginEmailPassword": "wdio run config/wdio.conf.ts --spec tests/login/emailPassword.spec.ts",
    "test:loginRememberMe": "wdio run config/wdio.conf.ts --spec tests/login/rememberMe.spec.ts",
    "test:catalog": "wdio run config/wdio.conf.ts --spec tests/catalog/*.spec.ts",
    "test:search": "wdio run config/wdio.conf.ts --spec tests/catalog/search.spec.ts",
    "test:category": "wdio run config/wdio.conf.ts --spec tests/catalog/category.spec.ts",
    "test:searchCategory": "wdio run config/wdio.conf.ts --spec tests/catalog/searchCategory.spec.ts",
    "test:productCard": "wdio run config/wdio.conf.ts --spec tests/catalog/productCard.spec.ts",
    "test:wishlist": "wdio run config/wdio.conf.ts --spec tests/catalog/wishlist.spec.ts",
    "test:longPress": "wdio run config/wdio.conf.ts --spec tests/catalog/longPress.spec.ts",
    "test:refresh": "wdio run config/wdio.conf.ts --spec tests/catalog/refresh.spec.ts",
    "test:cart": "wdio run config/wdio.conf.ts --spec tests/catalog/cart.spec.ts",
    "test:product-view": "wdio run config/wdio.conf.ts --spec tests/catalog/productView.spec.ts",
    "test:e2e": "wdio run config/wdio.conf.ts --spec tests/e2e/purchaseFlow.spec.ts",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"config/**/*.ts\""
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/appium-service": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "allure-commandline": "^2.30.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-wdio": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "webdriverio": "^9.0.0"
  }
}
